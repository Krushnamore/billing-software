# ─────────────────────────────────────────────────────────
#  BillCraft Backend — Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────

# ── MongoDB Atlas Connection String ──────────────────────
# Get this from MongoDB Atlas dashboard (see README for steps)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/billcraft?retryWrites=true&w=majority

# ── JWT Secret ───────────────────────────────────────────
# Use any long random string (32+ characters)
# Example: openssl rand -base64 32
JWT_SECRET=change_this_to_a_long_random_secret_string

# ── Server ───────────────────────────────────────────────
PORT=4000
FRONTEND_URL=http://localhost:5173
